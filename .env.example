# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/artlogic"

# JWT Secret (min 32 random chars)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# Admin credentials
ADMIN_EMAIL="admin@artlogic.com.ua"
# Generate hash: node -e "require('bcryptjs').hash('yourpassword', 10).then(console.log)"
ADMIN_PASSWORD_HASH="$2b$10$..."

# Resend email API (https://resend.com)
RESEND_API_KEY="re_..."
RESEND_FROM="notifications@artlogic.com.ua"
RESEND_ADMIN_TO="your-email@example.com"

# App URL
NEXT_PUBLIC_APP_URL="https://artlogic.com.ua"
